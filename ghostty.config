# Restored visual settings
cursor-style-blink = false
shell-integration-features = no-cursor
background = #020728
background-opacity = .8
background-blur = true
font-family = JetBrainsMono Nerd Font

# Ghostty clipboard behavior for terminal apps (OSC 52)
clipboard-write = allow
clipboard-read = ask

# Copy selected text to both selection + system clipboard
copy-on-select = clipboard

# Explicit common macOS clipboard bindings
keybind = super+c=copy_to_clipboard
keybind = super+v=paste_from_clipboard

# Copy with `y` only when there is an active selection; otherwise `y` is sent normally.
keybind = performable:y=copy_to_clipboard